# Python path - required so that 'app' module is resolvable from project root
PYTHONPATH=.
OPENAI_API_KEY=your_openai_api_key_here
WEAVIATE_URL=http://localhost:8080
# Leave WEAVIATE_API_KEY empty for local Docker instance
# Set it only when connecting to Weaviate Cloud
WEAVIATE_API_KEY=
DATABASE_URL=sqlite:///./parking.db
ENVIRONMENT=development
LOG_LEVEL=INFO
# LangGraph checkpointer database (filesystem path, not a URL)
CHECKPOINT_DB_PATH=checkpoints.db
